# ==================================================
# Database Configuration
# ==================================================
MONGODB_URI=mongodb://localhost:27017/bank-transaction-system
# Example for MongoDB Atlas:
# MONGODB_URI=mongodb+srv://username:password@cluster.mongodb.net/bank-transaction-system?retryWrites=true&w=majority

# ==================================================
# Server Configuration
# ==================================================
PORT=5000

# ==================================================
# Email Configuration (EmailJS)
# ==================================================
# Get these values from https://www.emailjs.com/
EMAILJS_SERVICE_ID=service_xxxxxxxxxxxxx
EMAILJS_TEMPLATE_ID=template_xxxxxxxxxxxxx
EMAILJS_PUBLIC_KEY=your_public_key_here
EMAILJS_PRIVATE_KEY=your_private_key_here

# Email sender configuration
EMAILJS_FROM_NAME=Royal Mint
EMAILJS_REPLY_TO=support@royalmint.com

# ==================================================
# Ledger Configuration
# ==================================================
# Set to "true" or "1" to enforce immutable ledger entries
# Set to "false" or "0" to allow ledger modifications (not recommended for production)
# If not set, defaults to true (immutable)
LEDGER_IMMUTABLE=true

# ==================================================
# Frontend URLs (for CORS)
# ==================================================
# Comma-separated list of allowed frontend origins
# FRONTEND_URLs=http://localhost:5173,http://localhost:5174

# ==================================================
# Authentication (Clerk)
# ==================================================
# Clerk configuration for user authentication
# CLERK_SECRET_KEY=your_clerk_secret_key_here

# ==================================================
# Notes
# ==================================================
# 1. MONGODB_URI: Connection string to MongoDB database
#    - For local development, use: mongodb://localhost:27017/bank-transaction-system
#    - For MongoDB Atlas, get the connection string from the cluster dashboard
#
# 2. EmailJS Configuration:
#    - Sign up at https://www.emailjs.com/
#    - Create a service and template
#    - Copy the Service ID, Template ID, and Keys here
#    - Template should accept these parameters:
#      * to_email, to_name, from_name, reply_to, app_name, email_type, subject
#      * For transactions: transactionId, amount, currency, status
#      * For failures: reason
#
# 3. LEDGER_IMMUTABLE:
#    - Default: true (recommended for production)
#    - When enabled, ledger entries cannot be updated/deleted
#    - Must create reversal entries instead
#
# 4. CLERK (if using Clerk authentication):
#    - Currently using x-clerk-id header for authentication
#    - This can be replaced with Clerk SDK for JWT validation
